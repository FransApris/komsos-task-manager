# .env.example
# The Gemini API Key is automatically provided by the platform.
# For other variables, prefix them with VITE_ to expose them to the client.

# Firebase Cloud Messaging — VAPID Key untuk Web Push Notification
# Cara mendapatkan:
#   1. Buka Firebase Console → Project Settings → Cloud Messaging
#   2. Scroll ke "Web configuration" → klik "Generate key pair"
#   3. Copy Key pair (Web Push certificates) ke sini
VITE_FIREBASE_VAPID_KEY=YOUR_VAPID_KEY_HERE
